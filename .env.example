# Google Maps
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google OAuth (for Google Sign In via Supabase)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_EXPO_GO_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_EXPO_GO_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-only — read by backend/trpc admin routes, never bundled into the app)
# Get this from Supabase Dashboard > Settings > API > service_role key. It bypasses RLS — keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack Payment (PAYSTACK_SECRET_KEY is server-only — read by backend/trpc, never bundled into the app)
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Flutterwave Payment (FLUTTERWAVE_SECRET_KEY is server-only — read by backend/trpc, never bundled into the app)
EXPO_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx

# App
EXPO_PUBLIC_RORK_API_BASE_URL=https://your-app.rork.app
